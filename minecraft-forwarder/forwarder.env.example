# Endpoint of bot running on external server
FORWARDER_TARGET_URL=http://YOUR_EXTERNAL_SERVER_IP:18080/minecraft/events

# Must match WEBHOOK_SHARED_SECRET on bot server
FORWARDER_SHARED_SECRET=change-this-secret

# Docker container name with Minecraft server
MC_DOCKER_CONTAINER=minecraft

LOG_LEVEL=INFO
RECONNECT_DELAY_SEC=3
DEDUPE_WINDOW_SEC=5
